{
  "name": "gamers-lounge-app",
  "version": "0.0.0",
  "private": true,
  "main": "src/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "electron:startdev": "nodemon --exec electron . --watch index.js",
    "start:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:startdev\""
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "concurrently": "^9.1.2",
    "electron": "^36.2.1",
    "electron-reloader": "^1.2.3",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "~10.0.0",
    "globals": "^16.0.0",
    "nodemon": "^3.1.10",
    "prettier": "3.5.3",
    "vite": "^6.2.4",
    "vite-plugin-vue-devtools": "^7.7.2",
    "wait-on": "^8.0.3"
  }
}
